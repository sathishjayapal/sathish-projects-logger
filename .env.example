# SathishLogger Environment Configuration
# Copy this file to .env and customize the values

# Server Configuration
SERVER_PORT=8080

# Database Configuration (PostgreSQL)
DATABASE_URL=jdbc:postgresql://postgres:8432/sathishlogger
DATABASE_USERNAME=sathish
DATABASE_PASSWORD=sathish123
DATABASE_DRIVER=org.postgresql.Driver
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# For H2 (in-memory database - development only)
# DATABASE_URL=jdbc:h2:mem:sathishlogger
# DATABASE_USERNAME=sa
# DATABASE_PASSWORD=
# DATABASE_DRIVER=org.h2.Driver
# HIBERNATE_DIALECT=org.hibernate.dialect.H2Dialect

# JPA Configuration
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# Logging Configuration
LOG_LEVEL=INFO
SPRING_WEB_LOG_LEVEL=WARN

# Storage Configuration
STORAGE_TYPE=database
STORAGE_FILE_PATH=./logs/application-logs.json

# Security Configuration
API_KEY_ENABLED=false
API_KEY=your-secret-api-key-here

# Retention Configuration
LOG_RETENTION_DAYS=30

# Batch Configuration
BATCH_MAX_SIZE=100

# PostgreSQL Configuration (for docker-compose)
POSTGRES_DB=sathishlogger
POSTGRES_PORT=8432

# Redis Configuration (optional)
REDIS_PORT=6379
